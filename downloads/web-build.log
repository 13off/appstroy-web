              'import \'../data/app_data_sync.dart\';\n'
              'import \'../data/app_state.dart\';\n'
              'import \'../data/attendance_repository.dart\';\n'
              'import \'../data/employee_repository.dart\';\n'
              'import \'../data/finance_summary_repository.dart\';\n'
              'import \'../data/object_repository.dart\';\n'
              'import \'../data/task_repository.dart\';\n'
              'import \'../features/ai/presentation/ai_assistant_screen.dart\';\n'
              'import \'../features/milestones/presentation/milestone_home_overlay.dart\';\n'
              'import \'../models/app_user_profile.dart\';\n'
              'import \'../models/employee.dart\';\n'
              'import \'../models/task_item_data.dart\';\n'
              'import \'../navigation/app_page_route.dart\';\n'
              'import \'../widgets/notification_bell.dart\';\n'
              'import \'../widgets/premium_ui.dart\';\n'
              '\n'
              'const Color _card = Color(0xFFFFFFFF);\n'
              'const Color _softCard = Color(0xFFF2F3F5);\n'
              'const Color _line = Color(0xFFE6E8EB);\n'
              'const Color _text = Color(0xFF1F2328);\n'
              'const Color _muted = Color(0xFF6B7075);\n'
              'const Color _accent = Color(0xFF8F9499);\n'
              'const Color _success = Color(0xFF22C55E);\n'
              '\n'
              'class HomeScreen extends StatefulWidget {\n'
              '  final AppUserProfile profile;\n'
              '  final String? selectedObjectName;\n'
              '  final ValueChanged<String?> onObjectChanged;\n'
              '\n'
              '  const HomeScreen({\n'
              '    super.key,\n'
              '    required this.profile,\n'
              '    required this.selectedObjectName,\n'
              '    required this.onObjectChanged,\n'
              '  });\n'
              '\n'
              '  @override\n'
              '  State<HomeScreen> createState() => _HomeScreenState();\n'
              '}\n'
              '\n'
              'class _HomeScreenState extends State<HomeScreen> {\n'
              '  static const String _allObjectsValue = \'__all__\';\n'
              '  static const String _addObjectValue = \'__add_object__\';\n'
              '  static const String _archiveListValue = \'__archive_list__\';\n'
              '  static const String _editObjectPrefix = \'__edit_object__::\';\n'
              '  static const String _archiveObjectPrefix = \'__archive_object__::\';\n'
              '\n'
              '  Future<_HomeDashboardData>? dashboardFuture;\n'
              '  Future<List<String>>? objectNamesFuture;\n'
              '  FinancePeriod financePeriod = FinancePeriod.current(AppState.today);\n'
              '  StreamSubscription<AppDataChange>? dataChangeSubscription;\n'
              '\n'
              '  @override\n'
              '  void initState() {\n'
              '    super.initState();\n'
              '    dashboardFuture = loadDashboardData();\n'
              '    objectNamesFuture = EmployeeRepository.fetchObjectNames();\n'
              '    dataChangeSubscription = AppDataSync.changes.listen(handleDataChange);\n'
              '  }\n'
              '\n'
              '  @override\n'
              '  void didUpdateWidget(covariant HomeScreen oldWidget) {\n'
              '    super.didUpdateWidget(oldWidget);\n'
              '\n'
              '    if (oldWidget.selectedObjectName != widget.selectedObjectName) {\n'
              '      dashboardFuture = loadDashboardData();\n'
              '    }\n'
              '  }\n'
              '\n'
              '  @override\n'
              '  void dispose() {\n'
              '    dataChangeSubscription?.cancel();\n'
              '    super.dispose();\n'
              '  }\n'
              '\n'
              '  void handleDataChange(AppDataChange change) {\n'
              '    const dashboardDomains = <AppDataDomain>{\n'
              '      AppDataDomain.attendance,\n'
              '      AppDataDomain.payments,\n'
              '      AppDataDomain.employees,\n'
              '      AppDataDomain.tasks,\n'
              '      AppDataDomain.objects,\n'
              '    };\n'
              '\n'
              '    if (!mounted || !change.affectsAny(dashboardDomains)) return;\n'
              '\n'
              '    final refreshObjects = change.affects(AppDataDomain.objects);\n'
              '\n'
              '    setState(() {\n'
              '      if (refreshObjects) {\n'
              '        objectNamesFuture = EmployeeRepository.fetchObjectNames(\n'
              '          forceRefresh: true,\n'
              '        );\n'
              '      }\n'
              '      dashboardFuture = loadDashboardData(forceRefresh: true);\n'
              '    });\n'
              '  }\n'
              '\n'
              '  String? cleanObjectName(String? value) {\n'
              '    final clean = value?.trim();\n'
              '\n'
              '    if (clean == null || clean.isEmpty) return null;\n'
              '\n'
              '    return clean;\n'
              '  }\n'
              '\n'
              '  String normalizeName(String value) {\n'
              '    return value.trim().toLowerCase().replaceAll(RegExp(r\'\\s+\'), \' \');\n'
              '  }\n'
              '\n'
              '  String get objectTitle {\n'
              '    return cleanObjectName(widget.selectedObjectName) ?? \'Все объекты\';\n'
              '  }\n'
              '\n'
              '  String dateText(DateTime date) {\n'
              '    const months = [\n'
              '      \'января\',\n'
              '      \'февраля\',\n'
              '      \'марта\',\n'
              '      \'апреля\',\n'
              '      \'мая\',\n'
              '      \'июня\',\n'
              '      \'июля\',\n'
              '      \'августа\',\n'
              '      \'сентября\',\n'
              '      \'октября\',\n'
              '      \'ноября\',\n'
              '      \'декабря\',\n'
              '    ];\n'
              '\n'
              '    return \'${date.day} ${months[date.month - 1]}\';\n'
              '  }\n'
              '\n'
              '  bool isSameObject(String? first, String? second) {\n'
              '    return cleanObjectName(first) == cleanObjectName(second);\n'
              '  }\n'
              '\n'
              '  bool isSameFinancePeriod(FinancePeriod first, FinancePeriod second) {\n'
              '    return first.year == second.year && first.month == second.month;\n'
              '  }\n'
              '\n'
              '  Future<_HomeDashboardData> loadDashboardData({\n'
              '    bool forceRefresh = false,\n'
              '  }) async {\n'
              '    final today = AppState.today;\n'
              '    final selectedObject = cleanObjectName(widget.selectedObjectName);\n'
              '\n'
              '    final results = await Future.wait<dynamic>([\n'
              '      EmployeeRepository.fetchEmployees(\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      AttendanceRepository.fetchWorkedEmployeeIds(\n'
              '        today,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      TaskRepository.fetchTasksForDate(\n'
              '        today,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      FinanceSummaryRepository.fetchSummary(\n'
              '        period: financePeriod,\n'
              '        objectName: selectedObject,\n'
              '        forceRefresh: forceRefresh,\n'
              '      ),\n'
              '      if (selectedObject == null)\n'
              '        ObjectRepository.fetchObjectNames(forceRefresh: forceRefresh),\n'
              '    ]);\n'
              '\n'
              '    final employees = results[0] as List<Employee>;\n'
              '    final workedEmployeeIds = results[1] as Set<String>;\n'
              '    var tasks = results[2] as List<TaskItemData>;\n'
              '\n'
              '    if (selectedObject == null) {\n'
              '      final activeObjectNames = (results[4] as List<String>).toSet();\n'
              '      tasks = tasks\n'
              '          .where((task) => activeObjectNames.contains(task.objectName.trim()))\n'
              '          .toList();\n'
              '    }\n'
              '\n'
              '    return _HomeDashboardData(\n'
              '      employees: employees,\n'
              '      workedEmployeeIds: workedEmployeeIds,\n'
              '      tasks: tasks,\n'
              '      finance: results[3] as FinanceSummaryData,\n'
              '    );\n'
              '  }\n'
              '\n'
              '  void refreshObjectsAndDashboard() {\n'
              '    ObjectRepository.clearCache();\n'
              '    EmployeeRepository.clearCache();\n'
              '    AttendanceRepository.clearCache();\n'
              '    TaskRepository.clearTaskListCache();\n'
              '    FinanceSummaryRepository.clearCache();\n'
              '\n'
              '    if (!mounted) return;\n'
              '\n'
              '    setState(() {\n'
              '      objectNamesFuture = EmployeeRepository.fetchObjectNames(\n'
              '        forceRefresh: true,\n'
              '      );\n'
              '      dashboardFuture = loadDashboardData(forceRefresh: true);\n'
              '    });\n'
              '  }\n'
              '\n'
              '  Future<String?> showObjectNameSheet({String? currentName}) async {\n'
              '    if (!widget.profile.isAdmin) return null;\n'
              '\n'
              '    final isEdit = currentName != null;\n'
              '    final formKey = GlobalKey<FormState>();\n'
              '    final controller = TextEditingController(text: currentName ?? \'\');\n'
              '    var isSaving = false;\n'
              '    String? errorText;\n'
              '\n'
              '    final result = await showModalBottomSheet<String>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return StatefulBuilder(\n'
              '          builder: (context, setModalState) {\n'
              '            Future<void> saveObject() async {\n'
              '              final isValid = formKey.currentState?.validate() ?? false;\n'
              '\n'
              '              if (!isValid || isSaving) return;\n'
              '\n'
              '              setModalState(() {\n'
              '                isSaving = true;\n'
              '                errorText = null;\n'
              '              });\n'
              '\n'
              '              try {\n'
              '                final savedName = isEdit\n'
              '                    ? await ObjectRepository.renameObject(\n'
              '                        oldName: currentName,\n'
              '                        newName: controller.text,\n'
              '                      )\n'
              '                    : await ObjectRepository.addObject(name: controller.text);\n'
              '\n'
              '                if (!sheetContext.mounted) return;\n'
              '                Navigator.pop(sheetContext, savedName);\n'
              '              } catch (error) {\n'
              '                if (!sheetContext.mounted) return;\n'
              '\n'
              '                setModalState(() {\n'
              '                  isSaving = false;\n'
              '                  errorText = error.toString();\n'
              '                });\n'
              '              }\n'
              '            }\n'
              '\n'
              '            return SafeArea(\n'
              '              child: Padding(\n'
              '                padding: EdgeInsets.only(\n'
              '                  left: 12,\n'
              '                  right: 12,\n'
              '                  top: 12,\n'
              '                  bottom: 12 + MediaQuery.of(context).viewInsets.bottom,\n'
              '                ),\n'
              '                child: Container(\n'
              '                  padding: const EdgeInsets.all(18),\n'
              '                  decoration: BoxDecoration(\n'
              '                    color: _card,\n'
              '                    borderRadius: BorderRadius.circular(28),\n'
              '                    border: Border.all(color: _line),\n'
              '                    boxShadow: [\n'
              '                      BoxShadow(\n'
              '                        color: Colors.black.withValues(alpha: 0.10),\n'
              '                        blurRadius: 28,\n'
              '                        offset: const Offset(0, 14),\n'
              '                      ),\n'
              '                    ],\n'
              '                  ),\n'
              '                  child: Form(\n'
              '                    key: formKey,\n'
              '                    child: Column(\n'
              '                      mainAxisSize: MainAxisSize.min,\n'
              '                      crossAxisAlignment: CrossAxisAlignment.start,\n'
              '                      children: [\n'
              '                        Center(\n'
              '                          child: Container(\n'
              '                            width: 44,\n'
              '                            height: 5,\n'
              '                            decoration: BoxDecoration(\n'
              '                              color: const Color(0xFFD4CCC2),\n'
              '                              borderRadius: BorderRadius.circular(100),\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                        const SizedBox(height: 18),\n'
              '                        Row(\n'
              '                          children: [\n'
              '                            Expanded(\n'
              '                              child: Text(\n'
              '                                isEdit\n'
              '                                    ? \'Редактировать объект\'\n'
              '                                    : \'Новый объект\',\n'
              '                                style: const TextStyle(\n'
              '                                  color: _text,\n'
              '                                  fontSize: 22,\n'
              '                                  fontWeight: FontWeight.w900,\n'
              '                                ),\n'
              '                              ),\n'
              '                            ),\n'
              '                            IconButton(\n'
              '                              onPressed: isSaving\n'
              '                                  ? null\n'
              '                                  : () => Navigator.pop(sheetContext),\n'
              '                              icon: const Icon(Icons.close),\n'
              '                            ),\n'
              '                          ],\n'
              '                        ),\n'
              '                        const SizedBox(height: 14),\n'
              '                        TextFormField(\n'
              '                          controller: controller,\n'
              '                          enabled: !isSaving,\n'
              '                          autofocus: true,\n'
              '                          textCapitalization: TextCapitalization.words,\n'
              '                          decoration: InputDecoration(\n'
              '                            labelText: \'Название объекта\',\n'
              '                            hintText: isEdit ? currentName : \'Например: Талнах\',\n'
              '                            border: const OutlineInputBorder(),\n'
              '                            prefixIcon: const Icon(Icons.business_outlined),\n'
              '                          ),\n'
              '                          validator: (value) {\n'
              '                            final text = value?.trim() ?? \'\';\n'
              '\n'
              '                            if (text.isEmpty) {\n'
              '                              return \'Введите название объекта\';\n'
              '                            }\n'
              '\n'
              '                            if (text.length < 2) {\n'
              '                              return \'Название слишком короткое\';\n'
              '                            }\n'
              '\n'
              '                            return null;\n'
              '                          },\n'
              '                          onFieldSubmitted: (_) => saveObject(),\n'
              '                        ),\n'
              '                        if (errorText != null) ...[\n'
              '                          const SizedBox(height: 12),\n'
              '                          Text(\n'
              '                            errorText!,\n'
              '                            style: const TextStyle(\n'
              '                              color: Colors.red,\n'
              '                              fontWeight: FontWeight.w700,\n'
              '                            ),\n'
              '                          ),\n'
              '                        ],\n'
              '                        const SizedBox(height: 16),\n'
              '                        SizedBox(\n'
              '                          width: double.infinity,\n'
              '                          height: 52,\n'
              '                          child: FilledButton.icon(\n'
              '                            onPressed: isSaving ? null : saveObject,\n'
              '                            icon: isSaving\n'
              '                                ? const SizedBox(\n'
              '                                    width: 18,\n'
              '                                    height: 18,\n'
              '                                    child: CircularProgressIndicator(\n'
              '                                      strokeWidth: 2,\n'
              '                                    ),\n'
              '                                  )\n'
              '                                : Icon(\n'
              '                                    isEdit\n'
              '                                        ? Icons.save_outlined\n'
              '                                        : Icons.add_business_outlined,\n'
              '                                  ),\n'
              '                            label: Text(\n'
              '                              isSaving\n'
              '                                  ? \'Сохраняем...\'\n'
              '                                  : isEdit\n'
              '                                  ? \'Сохранить\'\n'
              '                                  : \'Создать\',\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                      ],\n'
              '                    ),\n'
              '                  ),\n'
              '                ),\n'
              '              ),\n'
              '            );\n'
              '          },\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    controller.dispose();\n'
              '    return result;\n'
              '  }\n'
              '\n'
              '  Future<void> handleAddObject() async {\n'
              '    final createdName = await showObjectNameSheet();\n'
              '\n'
              '    if (createdName == null || createdName.trim().isEmpty) return;\n'
              '\n'
              '    widget.onObjectChanged(createdName);\n'
              '    refreshObjectsAndDashboard();\n'
              '  }\n'
              '\n'
              '  Future<void> handleRenameObject(String oldName) async {\n'
              '    final newName = await showObjectNameSheet(currentName: oldName);\n'
              '\n'
              '    if (newName == null || newName.trim().isEmpty) return;\n'
              '\n'
              '    if (isSameObject(widget.selectedObjectName, oldName)) {\n'
              '      widget.onObjectChanged(newName);\n'
              '    }\n'
              '\n'
              '    refreshObjectsAndDashboard();\n'
              '  }\n'
              '\n'
              '  Future<void> handleArchiveObject(String objectName) async {\n'
              '    final confirmed = await showDialog<bool>(\n'
              '      context: context,\n'
              '      builder: (dialogContext) {\n'
              '        return AlertDialog(\n'
              '          title: const Text(\'Архивировать объект?\'),\n'
              '          content: Text(\n'
              '            \'Объект "$objectName" исчезнет из рабочего списка. Табели, задачи, выплаты и документы сохранятся. Сотрудники на этом объекте будут отмечены как уволенные.\',\n'
              '          ),\n'
              '          actions: [\n'
              '            TextButton(\n'
              '              onPressed: () => Navigator.pop(dialogContext, false),\n'
              '              child: const Text(\'Отмена\'),\n'
              '            ),\n'
              '            FilledButton.icon(\n'
              '              onPressed: () => Navigator.pop(dialogContext, true),\n'
              '              icon: const Icon(Icons.archive_outlined),\n'
              '              label: const Text(\'В архив\'),\n'
              '            ),\n'
              '          ],\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (confirmed != true) return;\n'
              '\n'
              '    try {\n'
              '      final wasSelected = isSameObject(widget.selectedObjectName, objectName);\n'
              '\n'
              '      await ObjectRepository.archiveObject(name: objectName);\n'
              '\n'
              '      if (wasSelected) {\n'
              '        widget.onObjectChanged(null);\n'
              '      }\n'
              '\n'
              '      refreshObjectsAndDashboard();\n'
              '\n'
              '      if (!mounted) return;\n'
              '\n'
              '      ScaffoldMessenger.of(context).showSnackBar(\n'
              '        SnackBar(content: Text(\'Объект "$objectName" перемещён в архив\')),\n'
              '      );\n'
              '    } catch (error) {\n'
              '      if (!mounted) return;\n'
              '\n'
              '      ScaffoldMessenger.of(\n'
              '        context,\n'
              '      ).showSnackBar(SnackBar(content: Text(error.toString())));\n'
              '    }\n'
              '  }\n'
              '\n'
              '  Future<void> showArchivedObjectsSheet(BuildContext context) async {\n'
              '    List<String> archivedObjects;\n'
              '\n'
              '    try {\n'
              '      archivedObjects = await ObjectRepository.fetchArchivedObjectNames(\n'
              '        forceRefresh: true,\n'
              '      );\n'
              '    } catch (error) {\n'
              '      if (!mounted) return;\n'
              '\n'
              '      ScaffoldMessenger.of(\n'
              '        this.context,\n'
              '      ).showSnackBar(SnackBar(content: Text(error.toString())));\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (!context.mounted) return;\n'
              '\n'
              '    await showModalBottomSheet<void>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return SafeArea(\n'
              '          child: Container(\n'
              '            margin: const EdgeInsets.all(12),\n'
              '            padding: const EdgeInsets.all(18),\n'
              '            constraints: BoxConstraints(\n'
              '              maxHeight: MediaQuery.of(sheetContext).size.height * 0.75,\n'
              '            ),\n'
              '            decoration: BoxDecoration(\n'
              '              color: _card,\n'
              '              borderRadius: BorderRadius.circular(28),\n'
              '              border: Border.all(color: _line),\n'
              '              boxShadow: [\n'
              '                BoxShadow(\n'
              '                  color: Colors.black.withValues(alpha: 0.10),\n'
              '                  blurRadius: 28,\n'
              '                  offset: const Offset(0, 14),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '            child: Column(\n'
              '              mainAxisSize: MainAxisSize.min,\n'
              '              children: [\n'
              '                Row(\n'
              '                  children: [\n'
              '                    const Expanded(\n'
              '                      child: Text(\n'
              '                        \'Архив объектов\',\n'
              '                        style: TextStyle(\n'
              '                          color: _text,\n'
              '                          fontSize: 22,\n'
              '                          fontWeight: FontWeight.w900,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                    IconButton(\n'
              '                      onPressed: () => Navigator.pop(sheetContext),\n'
              '                      icon: const Icon(Icons.close),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '                const SizedBox(height: 10),\n'
              '                if (archivedObjects.isEmpty)\n'
              '                  const Padding(\n'
              '                    padding: EdgeInsets.symmetric(vertical: 30),\n'
              '                    child: Column(\n'
              '                      children: [\n'
              '                        Icon(\n'
              '                          Icons.inventory_2_outlined,\n'
              '                          size: 42,\n'
              '                          color: _muted,\n'
              '                        ),\n'
              '                        SizedBox(height: 10),\n'
              '                        Text(\n'
              '                          \'Архив пуст\',\n'
              '                          style: TextStyle(\n'
              '                            color: _muted,\n'
              '                            fontWeight: FontWeight.w700,\n'
              '                          ),\n'
              '                        ),\n'
              '                      ],\n'
              '                    ),\n'
              '                  )\n'
              '                else\n'
              '                  Flexible(\n'
              '                    child: ListView.separated(\n'
              '                      shrinkWrap: true,\n'
              '                      itemCount: archivedObjects.length,\n'
              '                      separatorBuilder: (_, _) => const SizedBox(height: 10),\n'
              '                      itemBuilder: (context, index) {\n'
              '                        final objectName = archivedObjects[index];\n'
              '\n'
              '                        return Container(\n'
              '                          padding: const EdgeInsets.fromLTRB(14, 10, 8, 10),\n'
              '                          decoration: BoxDecoration(\n'
              '                            color: _softCard,\n'
              '                            borderRadius: BorderRadius.circular(18),\n'
              '                            border: Border.all(color: _line),\n'
              '                          ),\n'
              '                          child: Row(\n'
              '                            children: [\n'
              '                              const Icon(Icons.inventory_2_outlined),\n'
              '                              const SizedBox(width: 12),\n'
              '                              Expanded(\n'
              '                                child: Text(\n'
              '                                  objectName,\n'
              '                                  overflow: TextOverflow.ellipsis,\n'
              '                                  style: const TextStyle(\n'
              '                                    color: _text,\n'
              '                                    fontWeight: FontWeight.w900,\n'
              '                                  ),\n'
              '                                ),\n'
              '                              ),\n'
              '                              TextButton.icon(\n'
              '                                onPressed: () async {\n'
              '                                  try {\n'
              '                                    await ObjectRepository.restoreObject(\n'
              '                                      name: objectName,\n'
              '                                    );\n'
              '\n'
              '                                    if (!sheetContext.mounted) return;\n'
              '                                    Navigator.pop(sheetContext);\n'
              '                                    refreshObjectsAndDashboard();\n'
              '\n'
              '                                    if (!mounted) return;\n'
              '                                    ScaffoldMessenger.of(\n'
              '                                      this.context,\n'
              '                                    ).showSnackBar(\n'
              '                                      SnackBar(\n'
              '                                        content: Text(\n'
              '                                          \'Объект "$objectName" восстановлен\',\n'
              '                                        ),\n'
              '                                      ),\n'
              '                                    );\n'
              '                                  } catch (error) {\n'
              '                                    if (!sheetContext.mounted) return;\n'
              '\n'
              '                                    ScaffoldMessenger.of(\n'
              '                                      sheetContext,\n'
              '                                    ).showSnackBar(\n'
              '                                      SnackBar(content: Text(error.toString())),\n'
              '                                    );\n'
              '                                  }\n'
              '                                },\n'
              '                                icon: const Icon(Icons.restore, size: 18),\n'
              '                                label: const Text(\'Вернуть\'),\n'
              '                              ),\n'
              '                            ],\n'
              '                          ),\n'
              '                        );\n'
              '                      },\n'
              '                    ),\n'
              '                  ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Future<void> showObjectPicker(\n'
              '    BuildContext context,\n'
              '    List<String> objects,\n'
              '  ) async {\n'
              '    if (!widget.profile.isAdmin) return;\n'
              '\n'
              '    final selectedValue = widget.selectedObjectName ?? _allObjectsValue;\n'
              '\n'
              '    final pickedValue = await showModalBottomSheet<String>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return SafeArea(\n'
              '          child: Container(\n'
              '            margin: const EdgeInsets.all(12),\n'
              '            padding: const EdgeInsets.all(18),\n'
              '            constraints: BoxConstraints(\n'
              '              maxHeight: MediaQuery.of(sheetContext).size.height * 0.82,\n'
              '            ),\n'
              '            decoration: BoxDecoration(\n'
              '              color: _card,\n'
              '              borderRadius: BorderRadius.circular(28),\n'
              '              border: Border.all(color: _line),\n'
              '              boxShadow: [\n'
              '                BoxShadow(\n'
              '                  color: Colors.black.withValues(alpha: 0.10),\n'
              '                  blurRadius: 28,\n'
              '                  offset: const Offset(0, 14),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '            child: Column(\n'
              '              mainAxisSize: MainAxisSize.min,\n'
              '              children: [\n'
              '                Container(\n'
              '                  width: 44,\n'
              '                  height: 5,\n'
              '                  decoration: BoxDecoration(\n'
              '                    color: const Color(0xFFD4CCC2),\n'
              '                    borderRadius: BorderRadius.circular(100),\n'
              '                  ),\n'
              '                ),\n'
              '                const SizedBox(height: 18),\n'
              '                Row(\n'
              '                  children: [\n'
              '                    const Expanded(\n'
              '                      child: Text(\n'
              '                        \'Выберите объект\',\n'
              '                        style: TextStyle(\n'
              '                          color: _text,\n'
              '                          fontSize: 22,\n'
              '                          fontWeight: FontWeight.w900,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                    IconButton(\n'
              '                      tooltip: \'Архив объектов\',\n'
              '                      onPressed: () {\n'
              '                        Navigator.pop(sheetContext, _archiveListValue);\n'
              '                      },\n'
              '                      icon: const Icon(Icons.inventory_2_outlined),\n'
              '                    ),\n'
              '                    FilledButton.tonalIcon(\n'
              '                      onPressed: () {\n'
              '                        Navigator.pop(sheetContext, _addObjectValue);\n'
              '                      },\n'
              '                      icon: const Icon(Icons.add, size: 18),\n'
              '                      label: const Text(\'Объект\'),\n'
              '                    ),\n'
              '                    const SizedBox(width: 4),\n'
              '                    IconButton(\n'
              '                      onPressed: () => Navigator.pop(sheetContext),\n'
              '                      icon: const Icon(Icons.close),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '                const SizedBox(height: 10),\n'
              '                Flexible(\n'
              '                  child: ListView(\n'
              '                    shrinkWrap: true,\n'
              '                    children: [\n'
              '                      _ObjectPickerTile(\n'
              '                        title: \'Все объекты\',\n'
              '                        subtitle: \'Сводка по всем активным объектам\',\n'
              '                        icon: Icons.apartment_outlined,\n'
              '                        isSelected: selectedValue == _allObjectsValue,\n'
              '                        onTap: () {\n'
              '                          Navigator.pop(sheetContext, _allObjectsValue);\n'
              '                        },\n'
              '                      ),\n'
              '                      ...objects.map((objectName) {\n'
              '                        return _ObjectPickerTile(\n'
              '                          title: objectName,\n'
              '                          subtitle: \'Данные только по этому объекту\',\n'
              '                          icon: Icons.business_outlined,\n'
              '                          isSelected: objectName == selectedValue,\n'
              '                          onTap: () {\n'
              '                            Navigator.pop(sheetContext, objectName);\n'
              '                          },\n'
              '                          onEdit: () {\n'
              '                            Navigator.pop(\n'
              '                              sheetContext,\n'
              '                              \'$_editObjectPrefix$objectName\',\n'
              '                            );\n'
              '                          },\n'
              '                          onArchive: () {\n'
              '                            Navigator.pop(\n'
              '                              sheetContext,\n'
              '                              \'$_archiveObjectPrefix$objectName\',\n'
              '                            );\n'
              '                          },\n'
              '                        );\n'
              '                      }),\n'
              '                    ],\n'
              '                  ),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (!context.mounted) return;\n'
              '    if (pickedValue == null) return;\n'
              '\n'
              '    if (pickedValue == _archiveListValue) {\n'
              '      await showArchivedObjectsSheet(context);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue == _addObjectValue) {\n'
              '      await handleAddObject();\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue.startsWith(_editObjectPrefix)) {\n'
              '      final objectName = pickedValue.substring(_editObjectPrefix.length);\n'
              '      await handleRenameObject(objectName);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue.startsWith(_archiveObjectPrefix)) {\n'
              '      final objectName = pickedValue.substring(_archiveObjectPrefix.length);\n'
              '      await handleArchiveObject(objectName);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (pickedValue == _allObjectsValue) {\n'
              '      widget.onObjectChanged(null);\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    widget.onObjectChanged(pickedValue);\n'
              '  }\n'
              '\n'
              '  Future<void> showFinancePeriodPicker(BuildContext context) async {\n'
              '    if (!widget.profile.isAdmin) return;\n'
              '\n'
              '    final periods = <FinancePeriod>[\n'
              '      const FinancePeriod.allTime(),\n'
              '      ...FinancePeriod.recentMonths(AppState.today, count: 18),\n'
              '    ];\n'
              '\n'
              '    final picked = await showModalBottomSheet<FinancePeriod>(\n'
              '      context: context,\n'
              '      isScrollControlled: true,\n'
              '      backgroundColor: Colors.transparent,\n'
              '      builder: (sheetContext) {\n'
              '        return SafeArea(\n'
              '          child: Container(\n'
              '            margin: const EdgeInsets.all(12),\n'
              '            padding: const EdgeInsets.all(18),\n'
              '            constraints: BoxConstraints(\n'
              '              maxHeight: MediaQuery.of(sheetContext).size.height * 0.82,\n'
              '            ),\n'
              '            decoration: BoxDecoration(\n'
              '              color: _card,\n'
              '              borderRadius: BorderRadius.circular(28),\n'
              '              border: Border.all(color: _line),\n'
              '            ),\n'
              '            child: Column(\n'
              '              mainAxisSize: MainAxisSize.min,\n'
              '              children: [\n'
              '                Row(\n'
              '                  children: [\n'
              '                    const Expanded(\n'
              '                      child: Text(\n'
              '                        \'Период выплат\',\n'
              '                        style: TextStyle(\n'
              '                          color: _text,\n'
              '                          fontSize: 22,\n'
              '                          fontWeight: FontWeight.w900,\n'
              '                        ),\n'
              '                      ),\n'
              '                    ),\n'
              '                    IconButton(\n'
              '                      onPressed: () => Navigator.pop(sheetContext),\n'
              '                      icon: const Icon(Icons.close),\n'
              '                    ),\n'
              '                  ],\n'
              '                ),\n'
              '                const SizedBox(height: 10),\n'
              '                Flexible(\n'
              '                  child: ListView.builder(\n'
              '                    shrinkWrap: true,\n'
              '                    itemCount: periods.length,\n'
              '                    itemBuilder: (context, index) {\n'
              '                      final period = periods[index];\n'
              '                      final isSelected = isSameFinancePeriod(\n'
              '                        period,\n'
              '                        financePeriod,\n'
              '                      );\n'
              '\n'
              '                      return Padding(\n'
              '                        padding: const EdgeInsets.only(bottom: 10),\n'
              '                        child: InkWell(\n'
              '                          borderRadius: BorderRadius.circular(18),\n'
              '                          onTap: () => Navigator.pop(sheetContext, period),\n'
              '                          child: Container(\n'
              '                            padding: const EdgeInsets.all(14),\n'
              '                            decoration: BoxDecoration(\n'
              '                              color: isSelected ? _softCard : _card,\n'
              '                              borderRadius: BorderRadius.circular(18),\n'
              '                              border: Border.all(\n'
              '                                color: isSelected ? _accent : _line,\n'
              '                              ),\n'
              '                            ),\n'
              '                            child: Row(\n'
              '                              children: [\n'
              '                                Icon(\n'
              '                                  period.isAllTime\n'
              '                                      ? Icons.all_inclusive\n'
              '                                      : Icons.calendar_month_outlined,\n'
              '                                ),\n'
              '                                const SizedBox(width: 12),\n'
              '                                Expanded(\n'
              '                                  child: Text(\n'
              '                                    period.pickerTitle(),\n'
              '                                    style: const TextStyle(\n'
              '                                      color: _text,\n'
              '                                      fontWeight: FontWeight.w900,\n'
              '                                    ),\n'
              '                                  ),\n'
              '                                ),\n'
              '                                if (isSelected)\n'
              '                                  const Icon(\n'
              '                                    Icons.check_circle,\n'
              '                                    color: _accent,\n'
              '                                  ),\n'
              '                              ],\n'
              '                            ),\n'
              '                          ),\n'
              '                        ),\n'
              '                      );\n'
              '                    },\n'
              '                  ),\n'
              '                ),\n'
              '              ],\n'
              '            ),\n'
              '          ),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '\n'
              '    if (picked == null || isSameFinancePeriod(picked, financePeriod)) return;\n'
              '\n'
              '    setState(() {\n'
              '      financePeriod = picked;\n'
              '      dashboardFuture = loadDashboardData();\n'
              '    });\n'
              '  }\n'
              '\n'
              '  void openAiAssistant(BuildContext context) {\n'
              '    Navigator.of(context).push(\n'
              '      AppPageRoute<void>(\n'
              '        builder: (_) => AiAssistantScreen(\n'
              '          profile: widget.profile,\n'
              '          selectedObjectName: widget.selectedObjectName,\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildAiAssistantButton(BuildContext context) {\n'
              '    return FloatingActionButton(\n'
              '      heroTag: \'home-ai-assistant\',\n'
              '      onPressed: () => openAiAssistant(context),\n'
              '      tooltip: \'ИИ-помощник\',\n'
              '      backgroundColor: _text,\n'
              '      foregroundColor: Colors.white,\n'
              '      elevation: 8,\n'
              '      child: const Icon(Icons.auto_awesome_rounded),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildObjectSelector(BuildContext context) {\n'
              '    if (!widget.profile.isAdmin) {\n'
              '      return _ObjectSelectorShell(\n'
              '        icon: Icons.lock_outline,\n'
              '        title: objectTitle,\n'
              '        onTap: null,\n'
              '      );\n'
              '    }\n'
              '\n'
              '    return FutureBuilder<List<String>>(\n'
              '      future: objectNamesFuture,\n'
              '      builder: (context, snapshot) {\n'
              '        final objects = snapshot.data ?? const <String>[];\n'
              '\n'
              '        return _ObjectSelectorShell(\n'
              '          icon: Icons.apartment_outlined,\n'
              '          title: objectTitle,\n'
              '          onTap: () => showObjectPicker(context, objects),\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildHeader(BuildContext context, DateTime today) {\n'
              '    return Column(\n'
              '      crossAxisAlignment: CrossAxisAlignment.stretch,\n'
              '      children: [\n'
              '        Row(\n'
              '          children: [\n'
              '            const Expanded(\n'
              '              child: Text(\n'
              '                \'Главная\',\n'
              '                style: TextStyle(\n'
              '                  color: _text,\n'
              '                  fontSize: 24,\n'
              '                  fontWeight: FontWeight.w900,\n'
              '                ),\n'
              '              ),\n'
              '            ),\n'
              '            NotificationBell(selectedObjectName: widget.selectedObjectName),\n'
              '          ],\n'
              '        ),\n'
              '        const SizedBox(height: 10),\n'
              '        PremiumWorkCard(\n'
              '          radius: 20,\n'
              '          padding: const EdgeInsets.all(10),\n'
              '          child: Column(\n'
              '            crossAxisAlignment: CrossAxisAlignment.stretch,\n'
              '            children: [\n'
              '              Row(\n'
              '                children: [\n'
              '                  const Icon(\n'
              '                    Icons.calendar_month_outlined,\n'
              '                    color: _muted,\n'
              '                    size: 18,\n'
              '                  ),\n'
              '                  const SizedBox(width: 8),\n'
              '                  Text(\n'
              '                    \'Сегодня, ${dateText(today)}\',\n'
              '                    style: const TextStyle(\n'
              '                      color: _muted,\n'
              '                      fontSize: 14,\n'
              '                      fontWeight: FontWeight.w700,\n'
              '                    ),\n'
              '                  ),\n'
              '                ],\n'
              '              ),\n'
              '              const SizedBox(height: 8),\n'
              '              buildObjectSelector(context),\n'
              '            ],\n'
              '          ),\n'
              '        ),\n'
              '      ],\n'
              '    );\n'
              '  }\n'
              '\n'
              '  Widget buildDashboard({\n'
              '    required BuildContext context,\n'
              '    required DateTime today,\n'
              '    required List<Employee> employees,\n'
              '    required Set<String> workedEmployeeIds,\n'
              '    required List<TaskItemData> tasks,\n'
              '    required FinanceSummaryData finance,\n'
              '    required bool isLoading,\n'
              '    required bool hasError,\n'
              '  }) {\n'
              '    final employeeById = <String, Employee>{};\n'
              '    final activeEmployeeNames = <String>{};\n'
              '\n'
              '    for (final employee in employees) {\n'
              '      final id = employee.id?.trim();\n'
              '\n'
              '      if (id != null && id.isNotEmpty) {\n'
              '        employeeById[id] = employee;\n'
              '      }\n'
              '\n'
              '      activeEmployeeNames.add(normalizeName(employee.name));\n'
              '    }\n'
              '\n'
              '    final workedEmployeeNames = <String>{};\n'
              '\n'
              '    for (final employeeId in workedEmployeeIds) {\n'
              '      final employee = employeeById[employeeId];\n'
              '\n'
              '      if (employee != null) {\n'
              '        workedEmployeeNames.add(normalizeName(employee.name));\n'
              '      }\n'
              '    }\n'
              '\n'
              '    final totalEmployees = activeEmployeeNames.length;\n'
              '    final workedEmployees = workedEmployeeNames.length;\n'
              '    final totalTasks = tasks.length;\n'
              '    final doneTasks = tasks.where((task) => task.status == \'Выполнено\').length;\n'
              '    final employeesProgress = totalEmployees == 0\n'
              '        ? 0.0\n'
              '        : workedEmployees / totalEmployees;\n'
              '    final tasksProgress = totalTasks == 0 ? 0.0 : doneTasks / totalTasks;\n'
              '\n'
              '    return PremiumWorkBackdrop(\n'
              '      child: SafeArea(\n'
              '        child: ListView(\n'
              '          padding: const EdgeInsets.fromLTRB(18, 18, 18, 120),\n'
              '          children: [\n'
              '            Center(\n'
              '              child: ConstrainedBox(\n'
              '                constraints: const BoxConstraints(maxWidth: 620),\n'
              '                child: Column(\n'
              '                  crossAxisAlignment: CrossAxisAlignment.start,\n'
              '                  children: [\n'
              '                    buildHeader(context, today),\n'
              '                    if (hasError) ...[\n'
              '                      const SizedBox(height: 14),\n'
              '                      const _SystemMessage(\n'
              '                        icon: Icons.error_outline,\n'
              '                        title: \'Есть ошибка загрузки\',\n'
              '                        text:\n'
              '                            \'Часть данных не подтянулась. Обнови страницу или проверь интернет.\',\n'
              '                      ),\n'
              '                    ],\n'
              '                    const SizedBox(height: 18),\n'
              '                    MilestoneHomeSection(\n'
              '                      profile: widget.profile,\n'
              '                      selectedObjectName: widget.selectedObjectName,\n'
              '                    ),\n'
              '                    const SizedBox(height: 18),\n'
              '                    _DashboardMetricCard(\n'
              '                      icon: Icons.person_outline,\n'
              '                      title: \'Сотрудники на объекте\',\n'
              '                      value: isLoading ? \'...\' : workedEmployees.toString(),\n'
              '                      secondaryValue: isLoading ? \'...\' : \'из $totalEmployees\',\n'
              '                      progress: employeesProgress,\n'
              '                      footerTitle: \'На объекте\',\n'
              '                      footerValue: isLoading\n'
              '                          ? \'...\'\n'
              '                          : workedEmployees.toString(),\n'
              '                      footerColor: _success,\n'
              '                    ),\n'
              '                    const SizedBox(height: 14),\n'
              '                    _DashboardMetricCard(\n'
              '                      icon: Icons.assignment_turned_in_outlined,\n'
              '                      title: \'Выполненные задачи\',\n'
              '                      value: isLoading ? \'...\' : doneTasks.toString(),\n'
              '                      secondaryValue: isLoading ? \'...\' : \'из $totalTasks\',\n'
              '                      progress: tasksProgress,\n'
              '                      footerTitle: \'За сегодня\',\n'
              '                      footerValue: isLoading ? \'...\' : doneTasks.toString(),\n'
              '                      footerColor: _accent,\n'
              '                    ),\n'
              '                    if (widget.profile.isAdmin) ...[\n'
              '                      const SizedBox(height: 14),\n'
              '                      _FinanceSummaryCard(\n'
              '                        title: \'Выплаты ${financePeriod.title()}\',\n'
              '                        objectTitle: objectTitle,\n'
              '                        finance: isLoading ? FinanceSummaryData.empty : finance,\n'
              '                        isLoading: isLoading,\n'
              '                        onPeriodTap: () => showFinancePeriodPicker(context),\n'
              '                      ),\n'
              '                    ],\n'
              '                  ],\n'
              '                ),\n'
              '              ),\n'
              '            ),\n'
              '          ],\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    final today = AppState.today;\n'
              '\n'
              '    return FutureBuilder<_HomeDashboardData>(\n'
              '      future: dashboardFuture,\n'
              '      builder: (context, snapshot) {\n'
              '        final data = snapshot.data ?? _HomeDashboardData.empty;\n'
              '        final isLoading =\n'
              '            snapshot.connectionState == ConnectionState.waiting &&\n'
              '            !snapshot.hasData;\n'
              '\n'
              '        return Stack(\n'
              '          children: [\n'
              '            buildDashboard(\n'
              '              context: context,\n'
              '              today: today,\n'
              '              employees: data.employees,\n'
              '              workedEmployeeIds: data.workedEmployeeIds,\n'
              '              tasks: data.tasks,\n'
              '              finance: data.finance,\n'
              '              isLoading: isLoading,\n'
              '              hasError: snapshot.hasError,\n'
              '            ),\n'
              '            Positioned(\n'
              '              right: 18,\n'
              '              bottom: 18,\n'
              '              child: SafeArea(\n'
              '                top: false,\n'
              '                left: false,\n'
              '                child: buildAiAssistantButton(context),\n'
              '              ),\n'
              '            ),\n'
              '          ],\n'
              '        );\n'
              '      },\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class _HomeDashboardData {\n'
              '  final List<Employee> employees;\n'
              '  final Set<String> workedEmployeeIds;\n'
              '  final List<TaskItemData> tasks;\n'
              '  final FinanceSummaryData finance;\n'
              '\n'
              '  const _HomeDashboardData({\n'
              '    required this.employees,\n'
              '    required this.workedEmployeeIds,\n'
              '    required this.tasks,\n'
              '    required this.finance,\n'
              '  });\n'
              '\n'
              '  static const empty = _HomeDashboardData(\n'
              '    employees: <Employee>[],\n'
              '    workedEmployeeIds: <String>{},\n'
              '    tasks: <TaskItemData>[],\n'
              '    finance: FinanceSummaryData.empty,\n'
              '  );\n'
              '}\n'
              '\n'
              'class _ObjectSelectorShell extends StatelessWidget {\n'
              '  final IconData icon;\n'
              '  final String title;\n'
              '  final VoidCallback? onTap;\n'
              '\n'
              '  const _ObjectSelectorShell({\n'
              '    required this.icon,\n'
              '    required this.title,\n'
              '    required this.onTap,\n'
              '  });\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    return InkWell(\n'
              '      borderRadius: BorderRadius.circular(16),\n'
              '      onTap: onTap,\n'
              '      child: Container(\n'
              '        width: double.infinity,\n'
              '        padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),\n'
              '        decoration: BoxDecoration(\n'
              '          color: _card,\n'
              '          borderRadius: BorderRadius.circular(16),\n'
              '          border: Border.all(color: _line),\n'
              '        ),\n'
              '        child: Row(\n'
              '          children: [\n'
              '            Container(\n'
              '              width: 36,\n'
              '              height: 36,\n'
              '              decoration: BoxDecoration(\n'
              '                color: _softCard,\n'
              '                borderRadius: BorderRadius.circular(12),\n'
              '              ),\n'
              '              child: Icon(icon, color: _text, size: 20),\n'
              '            ),\n'
              '            const SizedBox(width: 10),\n'
              '            Expanded(\n'
              '              child: Text(\n'
              '                title,\n'
              '                overflow: TextOverflow.ellipsis,\n'
              '                style: const TextStyle(\n'
              '                  color: _text,\n'
              '                  fontSize: 16,\n'
              '                  fontWeight: FontWeight.w800,\n'
              '                ),\n'
              '              ),\n'
              '            ),\n'
              '            if (onTap != null)\n'
              '              const Icon(Icons.keyboard_arrow_down, color: _text, size: 20),\n'
              '          ],\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class _ObjectPickerTile extends StatelessWidget {\n'
              '  final String title;\n'
              '  final String subtitle;\n'
              '  final IconData icon;\n'
              '  final bool isSelected;\n'
              '  final VoidCallback onTap;\n'
              '  final VoidCallback? onEdit;\n'
              '  final VoidCallback? onArchive;\n'
              '\n'
              '  const _ObjectPickerTile({\n'
              '    required this.title,\n'
              '    required this.subtitle,\n'
              '    required this.icon,\n'
              '    required this.isSelected,\n'
