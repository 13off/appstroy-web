              '    \'foreman_fill_tasks\': ReminderDefinition(\n'
              '      title: \'Заполнить задачи на день\',\n'
              '      description:\n'
              '          \'Напомнить прорабу, если на объекте ещё нет задач на сегодня.\',\n'
              '      recipientRole: \'foreman\',\n'
              '      defaultTime: \'08:00\',\n'
