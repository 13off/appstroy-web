              '    try {\n'
              '      await _client.rpc<void>(\'refresh_operational_notifications\');\n'
              '    } catch (_) {\n'
              '      // Старые уведомления остаются доступны при временной ошибке обновления.\n'
              '    }\n'
              '  }\n'
