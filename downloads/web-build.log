              '    \'hr\',\n'
              '    \'payments\',\n'
              '    \'legal\',\n'
              '    \'system\',\n'
              '  ];\n'
              '\n'
              '  static const Map<String, String> notificationEventGroupTitles =\n'
              '      <String, String>{\n'
              '        \'tasks\': \'Задачи и фотографии работ\',\n'
              '        \'attendance\': \'Табель и присутствие\',\n'
              '        \'employees\': \'Сотрудники и личные данные\',\n'
              '        \'hr\': \'Кандидаты и кадровая работа\',\n'
              '        \'payments\': \'Выплаты и чеки\',\n'
              '        \'legal\': \'Юридические события\',\n'
              '        \'system\': \'Системные и общие события\',\n'
              '      };\n'
              '\n'
              '  static const Map<String, ReminderDefinition>\n'
              '  reminderDefinitions = <String, ReminderDefinition>{\n'
              '    \'foreman_brigade_photo\': ReminderDefinition(\n'
              '      title: \'Утреннее фото бригады\',\n'
              '      description: \'Напомнить прорабу сделать и прикрепить фото бригады.\',\n'
              '      recipientRole: \'foreman\',\n'
              '      defaultTime: \'07:30\',\n'
