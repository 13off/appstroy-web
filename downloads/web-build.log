              '      description: \'Сообщать HR о переписках, где кандидат ожидает ответа.\',\n'
              '      recipientRole: \'hr\',\n'
              '      defaultTime: \'16:00\',\n'
              '    ),\n'
              '    \'accountant_missing_receipts\': ReminderDefinition(\n'
              '      title: \'Выплаты без чеков\',\n'
              '      description: \'Напоминать бухгалтеру о выплатах без прикреплённых чеков.\',\n'
              '      recipientRole: \'accountant\',\n'
              '      defaultTime: \'10:00\',\n'
              '    ),\n'
              '    \'lawyer_due_summary\': ReminderDefinition(\n'
              '      title: \'Юридические сроки\',\n'
              '      description: \'Напоминать юристу о ближайших и просроченных сроках.\',\n'
              '      recipientRole: \'lawyer\',\n'
              '      defaultTime: \'08:45\',\n'
              '    ),\n'
              '    \'admin_evening_summary\': ReminderDefinition(\n'
              '      title: \'Итоги рабочего дня\',\n'
              '      description: \'Напоминать руководителю проверить незакрытые направления.\',\n'
              '      recipientRole: \'admin\',\n'
              '      defaultTime: \'18:00\',\n'
              '    ),\n'
              '  };\n'
              '\n'
              '  static String? cleanObjectName(String? objectName) {\n'
              '    final clean = objectName?.trim();\n'
              '    return clean == null || clean.isEmpty ? null : clean;\n'
              '  }\n'
              '\n'
              '  static bool _isMissingNotificationsTableError(Object error) {\n'
              '    final text = error.toString().toLowerCase();\n'
              '    return text.contains(\'42p01\') ||\n'
              '        text.contains(\'app_notifications\') &&\n'
              '            (text.contains(\'relation\') || text.contains(\'schema cache\')) ||\n'
              '        text.contains(\'app_notification_reads\') &&\n'
              '            (text.contains(\'relation\') || text.contains(\'schema cache\')) ||\n'
              '        text.contains(\'app_notification_clears\') &&\n'
              '            (text.contains(\'relation\') || text.contains(\'schema cache\'));\n'
              '  }\n'
              '\n'
              '  static String? get _currentUserId => UserRepository.currentUser?.id;\n'
              '\n'
              '  static Future<String> currentActorName() async {\n'
              '    try {\n'
              '      final profile = await UserRepository.fetchCurrentProfile();\n'
              '      final fullName = profile?.fullName.trim() ?? \'\';\n'
              '      if (fullName.isNotEmpty) return fullName;\n'
              '      final email = profile?.email.trim() ?? \'\';\n'
              '      if (email.isNotEmpty) return email;\n'
              '    } catch (_) {\n'
              '      // Не ломаем рабочее действие из-за профиля.\n'
              '    }\n'
              '    final email = UserRepository.currentUser?.email?.trim() ?? \'\';\n'
              '    return email.isEmpty ? \'Пользователь\' : email;\n'
              '  }\n'
              '\n'
              '  static Future<void> add({\n'
              '    required String title,\n'
              '    required String body,\n'
              '    String? objectName,\n'
              '    String entityType = \'\',\n'
              '    String entityId = \'\',\n'
              '    String? targetUserId,\n'
              '    String? targetRole,\n'
              '    bool requiresAction = false,\n'
              '    DateTime? dueAt,\n'
              '    String priority = \'normal\',\n'
              '  }) async {\n'
              '    try {\n'
              '      final profile = await UserRepository.fetchCurrentProfile();\n'
              '      final user = UserRepository.currentUser;\n'
              '      final actorName = profile?.fullName.trim().isNotEmpty == true\n'
              '          ? profile!.fullName.trim()\n'
              '          : profile?.email.trim().isNotEmpty == true\n'
              '          ? profile!.email.trim()\n'
              '          : user?.email?.trim().isNotEmpty == true\n'
              '          ? user!.email!.trim()\n'
              '          : \'Пользователь\';\n'
              '      final actorEmail = profile?.email.trim().isNotEmpty == true\n'
              '          ? profile!.email.trim()\n'
              '          : user?.email?.trim() ?? \'\';\n'
              '      final cleanTargetUser = targetUserId?.trim() ?? \'\';\n'
              '      final cleanTargetRole = targetRole?.trim() ?? \'\';\n'
              '\n'
              '      final inserted = await _client\n'
              '          .from(\'app_notifications\')\n'
              '          .insert(<String, dynamic>{\n'
              '            \'title\': title.trim(),\n'
              '            \'body\': body.trim(),\n'
              '            \'actor_user_id\': user?.id,\n'
              '            \'actor_name\': actorName,\n'
              '            \'actor_email\': actorEmail,\n'
              '            \'object_name\': cleanObjectName(objectName) ?? \'\',\n'
              '            \'entity_type\': entityType.trim(),\n'
              '            \'entity_id\': entityId.trim(),\n'
              '            \'target_user_id\': cleanTargetUser.isEmpty ? null : cleanTargetUser,\n'
              '            \'target_role\': cleanTargetRole.isEmpty ? null : cleanTargetRole,\n'
              '            \'requires_action\': requiresAction,\n'
              '            \'due_at\': dueAt?.toUtc().toIso8601String(),\n'
              '            \'priority\':\n'
              '                <String>{\'low\', \'normal\', \'high\', \'critical\'}.contains(priority)\n'
              '                ? priority\n'
              '                : \'normal\',\n'
              '          })\n'
              '          .select(\'id\')\n'
              '          .maybeSingle();\n'
              '\n'
              '      AppDataSync.notifyLocal(\n'
              '        const <AppDataDomain>{AppDataDomain.notifications},\n'
              '        context: <String, dynamic>{\n'
              '          \'table\': \'app_notifications\',\n'
              '          \'object_name\': cleanObjectName(objectName),\n'
              '        },\n'
              '      );\n'
              '\n'
              '      final notificationId = inserted?[\'id\']?.toString().trim() ?? \'\';\n'
              '      if (notificationId.isNotEmpty) {\n'
              '        unawaited(PushNotificationService.dispatchNotification(notificationId));\n'
              '      }\n'
              '    } catch (error) {\n'
              '      if (_isMissingNotificationsTableError(error)) return;\n'
              '      // Уведомления не должны ломать основное действие.\n'
              '    }\n'
              '  }\n'
              '\n'
              '  static Future<Set<String>> fetchSelectedNotificationRoles() async {\n'
              '    final data = await _client.rpc(\'get_my_notification_role_preferences\');\n'
              '    if (data is List) {\n'
              '      return data\n'
              '          .map((value) => value.toString())\n'
              '          .where(allNotificationRoles.contains)\n'
              '          .toSet();\n'
              '    }\n'
              '    return allNotificationRoles.toSet();\n'
              '  }\n'
              '\n'
              '  static Future<Set<String>> saveSelectedNotificationRoles(\n'
              '    Iterable<String> roles,\n'
              '  ) async {\n'
              '    final clean = roles\n'
              '        .map((role) => role.trim())\n'
              '        .where(allNotificationRoles.contains)\n'
              '        .toSet()\n'
              '        .toList();\n'
              '    final data = await _client.rpc(\n'
              '      \'set_my_notification_role_preferences\',\n'
              '      params: <String, dynamic>{\'p_roles\': clean},\n'
              '    );\n'
              '    AppDataSync.notifyLocal(\n'
              '      const <AppDataDomain>{AppDataDomain.notifications},\n'
              '      context: const <String, dynamic>{\n'
              '        \'table\': \'notification_role_preferences\',\n'
              '      },\n'
              '    );\n'
              '    if (data is List) {\n'
              '      return data\n'
              '          .map((value) => value.toString())\n'
              '          .where(allNotificationRoles.contains)\n'
              '          .toSet();\n'
              '    }\n'
              '    return clean.toSet();\n'
              '  }\n'
              '\n'
              '  static Set<String> _stringSet(dynamic value, Iterable<String> allowed) {\n'
              '    final allowedSet = allowed.toSet();\n'
              '    if (value is! List) return <String>{};\n'
              '    return value\n'
              '        .map((item) => item.toString().trim())\n'
              '        .where(allowedSet.contains)\n'
              '        .toSet();\n'
              '  }\n'
              '\n'
              '  static NotificationControlCenterData _controlCenterFromRpc(dynamic data) {\n'
              '    if (data is! Map) {\n'
              '      return NotificationControlCenterData(\n'
              '        settings: NotificationControlSettings.defaults(),\n'
              '        reminders: reminderDefinitions.entries\n'
              '            .map(\n'
              '              (entry) => ReminderControlSetting(\n'
              '                key: entry.key,\n'
              '                recipientRole: entry.value.recipientRole,\n'
              '                enabled: false,\n'
              '                localTime: entry.value.defaultTime,\n'
              '              ),\n'
              '            )\n'
              '            .toList(),\n'
              '      );\n'
              '    }\n'
              '    final map = Map<String, dynamic>.from(data);\n'
              '    final roleSet = _stringSet(map[\'selected_roles\'], allNotificationRoles);\n'
              '    final eventSet = _stringSet(\n'
              '      map[\'selected_event_groups\'],\n'
              '      allNotificationEventGroups,\n'
              '    );\n'
              '    final reminderByKey = <String, ReminderControlSetting>{};\n'
              '    final rawReminders = map[\'reminders\'];\n'
              '    if (rawReminders is List) {\n'
              '      for (final item in rawReminders) {\n'
              '        if (item is! Map) continue;\n'
              '        final row = Map<String, dynamic>.from(item);\n'
              '        final key = row[\'key\']?.toString().trim() ?? \'\';\n'
              '        final definition = reminderDefinitions[key];\n'
              '        if (definition == null) continue;\n'
              '        reminderByKey[key] = ReminderControlSetting(\n'
              '          key: key,\n'
              '          recipientRole:\n'
              '              row[\'recipient_role\']?.toString().trim().isNotEmpty == true\n'
              '              ? row[\'recipient_role\'].toString().trim()\n'
              '              : definition.recipientRole,\n'
              '          enabled: row[\'enabled\'] == true,\n'
              '          localTime: row[\'local_time\']?.toString().trim().isNotEmpty == true\n'
              '              ? row[\'local_time\'].toString().trim()\n'
              '              : definition.defaultTime,\n'
              '        );\n'
              '      }\n'
              '    }\n'
              '    final reminders = reminderDefinitions.entries.map((entry) {\n'
              '      return reminderByKey[entry.key] ??\n'
              '          ReminderControlSetting(\n'
              '            key: entry.key,\n'
              '            recipientRole: entry.value.recipientRole,\n'
              '            enabled: false,\n'
              '            localTime: entry.value.defaultTime,\n'
              '          );\n'
              '    }).toList();\n'
              '    return NotificationControlCenterData(\n'
              '      settings: NotificationControlSettings(\n'
              '        inAppEnabled: map[\'in_app_enabled\'] != false,\n'
              '        pushEnabled: map[\'push_enabled\'] != false,\n'
              '        selectedRoles: roleSet,\n'
              '        selectedEventGroups: eventSet,\n'
              '      ),\n'
              '      reminders: reminders,\n'
              '    );\n'
              '  }\n'
              '\n'
              '  static Future<NotificationControlCenterData>\n'
              '  fetchNotificationControlCenter() async {\n'
              '    final data = await _client.rpc(\'get_my_notification_control_center\');\n'
              '    return _controlCenterFromRpc(data);\n'
              '  }\n'
              '\n'
              '  static Future<NotificationControlCenterData> saveNotificationControlCenter({\n'
              '    required NotificationControlSettings settings,\n'
              '    required List<ReminderControlSetting> reminders,\n'
              '  }) async {\n'
              '    await _client.rpc(\n'
              '      \'set_my_notification_control_preferences\',\n'
              '      params: <String, dynamic>{\n'
              '        \'p_in_app_enabled\': settings.inAppEnabled,\n'
              '        \'p_push_enabled\': settings.pushEnabled,\n'
              '        \'p_roles\': settings.selectedRoles.toList(),\n'
              '        \'p_event_groups\': settings.selectedEventGroups.toList(),\n'
              '      },\n'
              '    );\n'
              '    final data = await _client.rpc(\n'
              '      \'set_company_reminder_settings\',\n'
              '      params: <String, dynamic>{\n'
              '        \'p_settings\': reminders\n'
              '            .map(\n'
              '              (item) => <String, dynamic>{\n'
              '                \'key\': item.key,\n'
              '                \'enabled\': item.enabled,\n'
              '                \'local_time\': item.localTime,\n'
              '              },\n'
              '            )\n'
              '            .toList(),\n'
              '      },\n'
              '    );\n'
              '    AppDataSync.notifyLocal(\n'
              '      const <AppDataDomain>{AppDataDomain.notifications},\n'
              '      context: const <String, dynamic>{\n'
              '        \'table\': \'notification_role_preferences\',\n'
              '      },\n'
              '    );\n'
              '    return _controlCenterFromRpc(data);\n'
              '  }\n'
              '\n'
              '  static Future<List<AppNotification>> fetchLatest({\n'
              '    String? objectName,\n'
              '    int limit = 40,\n'
              '    bool refreshOperational = false,\n'
              '  }) async {\n'
              '    final cleanObject = cleanObjectName(objectName);\n'
              '    if (refreshOperational) await _refreshOperationalNotifications();\n'
              '    try {\n'
              '      final response = await _client.rpc<dynamic>(\n'
              '        \'get_notification_feed_fast\',\n'
              '        params: <String, dynamic>{\n'
              '          \'p_object_name\': cleanObject,\n'
              '          \'p_limit\': limit,\n'
              '        },\n'
              '      );\n'
              '      if (response is! List) return <AppNotification>[];\n'
              '\n'
              '      return response\n'
              '          .whereType<Map>()\n'
              '          .map((row) => Map<String, dynamic>.from(row))\n'
