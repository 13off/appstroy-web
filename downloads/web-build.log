              '    this.sourceRole = \'admin\',\n'
              '    this.requiresAction = false,\n'
              '    this.dueAt,\n'
              '    this.priority = \'normal\',\n'
              '    required this.createdAt,\n'
              '    required this.isRead,\n'
              '  });\n'
              '\n'
              '  factory AppNotification.fromSupabase(\n'
              '    Map<String, dynamic> json, {\n'
              '    bool isRead = false,\n'
              '  }) {\n'
              '    final dueText = json[\'due_at\']?.toString().trim() ?? \'\';\n'
              '    return AppNotification(\n'
              '      id: json[\'id\']?.toString() ?? \'\',\n'
              '      title: json[\'title\']?.toString() ?? \'Изменение\',\n'
              '      body: json[\'body\']?.toString() ?? \'\',\n'
              '      actorUserId: json[\'actor_user_id\']?.toString() ?? \'\',\n'
              '      actorName: json[\'actor_name\']?.toString() ?? \'Пользователь\',\n'
              '      actorEmail: json[\'actor_email\']?.toString() ?? \'\',\n'
              '      objectName: json[\'object_name\']?.toString() ?? \'\',\n'
              '      entityType: json[\'entity_type\']?.toString() ?? \'\',\n'
              '      entityId: json[\'entity_id\']?.toString() ?? \'\',\n'
              '      targetUserId: json[\'target_user_id\']?.toString() ?? \'\',\n'
              '      targetRole: json[\'target_role\']?.toString() ?? \'\',\n'
              '      sourceRole: json[\'source_role\']?.toString() ?? \'admin\',\n'
              '      requiresAction: json[\'requires_action\'] == true,\n'
              '      dueAt: dueText.isEmpty ? null : DateTime.tryParse(dueText)?.toLocal(),\n'
              '      priority: json[\'priority\']?.toString() ?? \'normal\',\n'
              '      createdAt:\n'
              '          DateTime.tryParse(json[\'created_at\']?.toString() ?? \'\') ??\n'
              '          DateTime.now(),\n'
              '      isRead: isRead,\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class ReminderDefinition {\n'
              '  final String title;\n'
              '  final String description;\n'
              '  final String recipientRole;\n'
              '  final String defaultTime;\n'
              '\n'
              '  const ReminderDefinition({\n'
              '    required this.title,\n'
              '    required this.description,\n'
              '    required this.recipientRole,\n'
              '    required this.defaultTime,\n'
              '  });\n'
              '}\n'
              '\n'
              'class NotificationControlSettings {\n'
              '  final bool inAppEnabled;\n'
              '  final bool pushEnabled;\n'
              '  final Set<String> selectedRoles;\n'
              '  final Set<String> selectedEventGroups;\n'
              '\n'
              '  const NotificationControlSettings({\n'
              '    required this.inAppEnabled,\n'
              '    required this.pushEnabled,\n'
              '    required this.selectedRoles,\n'
              '    required this.selectedEventGroups,\n'
              '  });\n'
              '\n'
              '  factory NotificationControlSettings.defaults() {\n'
              '    return NotificationControlSettings(\n'
              '      inAppEnabled: true,\n'
              '      pushEnabled: true,\n'
              '      selectedRoles: NotificationRepository.allNotificationRoles.toSet(),\n'
              '      selectedEventGroups: NotificationRepository.allNotificationEventGroups\n'
              '          .toSet(),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  NotificationControlSettings copyWith({\n'
              '    bool? inAppEnabled,\n'
              '    bool? pushEnabled,\n'
              '    Set<String>? selectedRoles,\n'
              '    Set<String>? selectedEventGroups,\n'
              '  }) {\n'
              '    return NotificationControlSettings(\n'
              '      inAppEnabled: inAppEnabled ?? this.inAppEnabled,\n'
              '      pushEnabled: pushEnabled ?? this.pushEnabled,\n'
              '      selectedRoles: selectedRoles ?? this.selectedRoles,\n'
              '      selectedEventGroups: selectedEventGroups ?? this.selectedEventGroups,\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class ReminderControlSetting {\n'
              '  final String key;\n'
              '  final String recipientRole;\n'
              '  final bool enabled;\n'
              '  final String localTime;\n'
              '\n'
              '  const ReminderControlSetting({\n'
              '    required this.key,\n'
              '    required this.recipientRole,\n'
              '    required this.enabled,\n'
              '    required this.localTime,\n'
              '  });\n'
              '\n'
              '  ReminderControlSetting copyWith({\n'
              '    String? recipientRole,\n'
              '    bool? enabled,\n'
              '    String? localTime,\n'
              '  }) {\n'
              '    return ReminderControlSetting(\n'
              '      key: key,\n'
              '      recipientRole: recipientRole ?? this.recipientRole,\n'
              '      enabled: enabled ?? this.enabled,\n'
              '      localTime: localTime ?? this.localTime,\n'
              '    );\n'
              '  }\n'
              '}\n'
              '\n'
              'class NotificationControlCenterData {\n'
              '  final NotificationControlSettings settings;\n'
              '  final List<ReminderControlSetting> reminders;\n'
              '\n'
              '  const NotificationControlCenterData({\n'
              '    required this.settings,\n'
              '    required this.reminders,\n'
              '  });\n'
              '}\n'
              '\n'
